{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "engine-vs-debug",
      "displayName": "Engine Debug (Visual Studio)",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/engine-vs-debug",
      "cacheVariables": {
        "DX21_BUILD_STANDALONE": "OFF",
        "DX21_BUILD_PLUGIN": "OFF"
      }
    },
    {
      "name": "standalone-vs-debug",
      "displayName": "Standalone Debug (Visual Studio)",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/standalone-vs-debug",
      "cacheVariables": {
        "DX21_BUILD_STANDALONE": "ON",
        "DX21_BUILD_PLUGIN": "ON"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/macos-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "DX21_BUILD_STANDALONE": "ON",
        "DX21_BUILD_PLUGIN": "ON",
        "DX21_BUILD_AU": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release"
    },
    {
      "name": "engine-vs-debug",
      "configurePreset": "engine-vs-debug",
      "configuration": "Debug",
      "targets": [
        "dx21_engine_tests"
      ]
    },
    {
      "name": "standalone-vs-debug",
      "configurePreset": "standalone-vs-debug",
      "configuration": "Debug",
      "targets": [
        "OpalineFM_Standalone"
      ]
    },
    {
      "name": "plugin-vs-debug",
      "configurePreset": "standalone-vs-debug",
      "configuration": "Debug",
      "targets": [
        "OpalineFM_Plugin_VST3"
      ]
    },
    {
      "name": "plugin-standalone-vs-debug",
      "configurePreset": "standalone-vs-debug",
      "configuration": "Debug",
      "targets": [
        "OpalineFM_Plugin_Standalone"
      ]
    },
    {
      "name": "plugin-au-macos-debug",
      "configurePreset": "macos-debug",
      "configuration": "Debug",
      "targets": [
        "OpalineFM_Plugin_AU"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "engine-vs-debug",
      "configurePreset": "engine-vs-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
