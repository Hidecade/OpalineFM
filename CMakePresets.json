{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "engine-vs-debug",
      "displayName": "Engine Debug (Visual Studio)",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/engine-vs-debug",
      "cacheVariables": {
        "DX21_BUILD_STANDALONE": "OFF",
        "DX21_BUILD_PLUGIN": "OFF"
      }
    },
    {
      "name": "standalone-vs-debug",
      "displayName": "Standalone Debug (Visual Studio)",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/standalone-vs-debug",
      "cacheVariables": {
        "DX21_BUILD_STANDALONE": "ON",
        "DX21_BUILD_PLUGIN": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release"
    },
    {
      "name": "engine-vs-debug",
      "configurePreset": "engine-vs-debug",
      "configuration": "Debug",
      "targets": [
        "dx21_engine_tests"
      ]
    },
    {
      "name": "standalone-vs-debug",
      "configurePreset": "standalone-vs-debug",
      "configuration": "Debug",
      "targets": [
        "DX21Native_Standalone"
      ]
    },
    {
      "name": "plugin-vs-debug",
      "configurePreset": "standalone-vs-debug",
      "configuration": "Debug",
      "targets": [
        "DX21Native_Plugin_VST3"
      ]
    },
    {
      "name": "plugin-standalone-vs-debug",
      "configurePreset": "standalone-vs-debug",
      "configuration": "Debug",
      "targets": [
        "DX21Native_Plugin_Standalone"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "engine-vs-debug",
      "configurePreset": "engine-vs-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
